{
  "hooks": [
    {
      "type": "command",
      "trigger": "SessionStart",
      "command": "pwsh -File .claude/hooks/engram-lite-session-start.ps1"
    },
    {
      "type": "command",
      "trigger": "Stop",
      "command": "pwsh -File .claude/hooks/engram-lite-session-end.ps1"
    },
    {
      "type": "command",
      "trigger": "PostToolUse(Edit|Write|NotebookEdit)",
      "command": "pwsh -File .claude/hooks/format-post-edit.ps1"
    },
    {
      "type": "command",
      "trigger": "PreToolUse(Bash)",
      "command": "pwsh -File .claude/hooks/git-guardrails-pre-bash.ps1"
    }
  ],
  "mcpServers": {
    "engram-lite": {
      "command": "engram-lite",
      "args": ["mcp", "--tools=agent"]
    }
  },
  "permissions": {
    "allowedTools": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch)",
      "mcp__engram_lite__mem_search",
      "mcp__engram_lite__mem_context",
      "mcp__engram_lite__mem_get_observation"
    ]
  }
}
